function selectPay(type){
  S.payMethod = type;
  ['upi','card','nb','wallet','emi'].forEach(t=>{
    const el = document.getElementById('pay-'+t);
    if(el){
      el.classList.toggle('on', t===type);
      const dot = el.querySelector('.pay-radio-dot');
      const ring = el.querySelector('.pay-radio');
      if(ring) ring.style.borderColor = t===type ? 'var(--accent)' : '';
    }
  });
  const ud = document.getElementById('upi-detail');
  if(ud) ud.style.display = type==='upi' ? '' : 'none';
}

function fillPromo(code){
  const inp = document.getElementById('promo-input');
  if(inp){ inp.value = code; applyPromo(); }
}
function applyPromo(){
  const msg = document.getElementById('promo-msg');
  if(msg){ msg.style.display='block'; }
}

function processPayment(total){
  const btn = document.getElementById('pay-now-btn');
  if(btn){ btn.textContent = '⟳ Processing...'; btn.disabled = true; btn.style.opacity = '0.7'; }
  setTimeout(()=>{
    S.pnr = Math.random().toString(36).substr(2,6).toUpperCase();
    buildConfirmScreen();
    goTo('screen-confirm');
  }, 1900);
}

