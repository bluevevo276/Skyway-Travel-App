          <div class="f-label">Gender</div>
          <select class="f-input f-select"><option>Male</option><option>Female</option><option>Other</option></select>
        </div>
      </div>
      <div class="form-field">
        <div class="f-label">Passport / ID Number</div>
        <input class="f-input" placeholder="Required for check-in">
      </div>`}
    </div>

    <!-- Contact -->
    <div class="form-section">
      <div class="form-sec-title">Contact Details</div>
      <div class="form-field">
        <div class="f-label">Email Address</div>
        <input class="f-input" type="email" value="arjun@email.com" placeholder="E-ticket will be sent here">
      </div>
      <div class="form-field" style="margin-bottom:0">
        <div class="f-label">Mobile Number</div>
        <input class="f-input" type="tel" value="+91 98765 43210" placeholder="+91 XXXXX XXXXX">
      </div>
    </div>

    <!-- Seat info (flight only) -->
    ${!isTrain && S.selectedSeats.length > 0 ? `
    <div class="form-section">
      <div class="form-sec-title">Selected Seats</div>
      <div style="font-family:Syne,sans-serif;font-size:18px;font-weight:700;color:var(--accent)">${S.selectedSeats.join(', ')}</div>
      <div style="font-size:11px;color:var(--text3);margin-top:4px">Terminal ${S.selectedFlight?.terminal} · ${S.selectedFlight?.aircraft}</div>
    </div>` : ''}

    <!-- GST (optional) -->
    <div class="form-section" style="border-color:rgba(255,255,255,0.05)">
      <div class="form-sec-title">GST Details (Optional)</div>
      <div class="form-2col">
        <div class="form-field">
          <div class="f-label">GSTIN</div>
          <input class="f-input" placeholder="22AAAAA0000A1Z5">
        </div>
        <div class="form-field">
          <div class="f-label">Company Name</div>
          <input class="f-input" placeholder="For business trips">
        </div>
      </div>
    </div>

    <!-- Price Summary -->
    <div class="form-section">
      <div class="form-sec-title">Price Summary</div>
      <div class="price-break-row"><span class="pb-label">Base Fare (${S.adults} adult)</span><span class="pb-value">₹${(basePrice*S.adults).toLocaleString('en-IN')}</span></div>
      ${S.children > 0 ? `<div class="price-break-row"><span class="pb-label">Children (${S.children})</span><span class="pb-value">₹${Math.round(basePrice*0.75*S.children).toLocaleString('en-IN')}</span></div>` : ''}
      <div class="price-break-row"><span class="pb-label">Taxes & Fees (18%)</span><span class="pb-value">₹${taxes.toLocaleString('en-IN')}</span></div>
      ${!isTrain ? `<div class="price-break-row"><span class="pb-label">Convenience Fee</span><span class="pb-value">₹119</span></div>` : ''}
      <div class="price-break-row total"><span class="pb-label-bold">Total Amount</span><span class="pb-value-bold">₹${total.toLocaleString('en-IN')}</span></div>
    </div>

    <div style="height:90px"></div>
    <div class="sticky-footer">
      <div>
        <div class="footer-price-label">Total</div>
        <div class="footer-price-big">₹${total.toLocaleString('en-IN')}</div>
      </div>
      <button class="cta-btn${isTrain?' teal':''}" onclick="goToPayment(${total})">Proceed to Pay →</button>
    </div>`;
  goTo('screen-booking');
}

function changePax(delta, type){
  if(type==='adults')  S.adults   = Math.max(1, Math.min(9, S.adults   + delta));
  if(type==='children') S.children = Math.max(0, Math.min(9, S.children + delta));
  const el = document.getElementById('pax-' + type);
  if(el) el.textContent = S[type];
}

/* ════════════════════════
   PAYMENT
════════════════════════ */
function goToPayment(total){
  const isTrain = S.travelType === 'train';
  const w = document.getElementById('payment-wrap');
  w.innerHTML = `
    <div class="back-row" onclick="goTo('screen-booking')"><div class="back-circle">←</div><span>Traveller Details</span></div>
    <div class="book-screen-title">Choose Payment</div>

    <div style="padding:0 16px">
      <div class="pay-option on" id="pay-upi" onclick="selectPay('upi')">
