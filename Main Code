    {d:'18',day:'Wed',mon:'Jun'},{d:'19',day:'Thu',mon:'Jun'},{d:'20',day:'Fri',mon:'Jun'},
  ];
  const dayFull = {Thu:'Thursday',Fri:'Friday',Sat:'Saturday',Sun:'Sunday',Mon:'Monday',Tue:'Tuesday',Wed:'Wednesday'};
  const overlay = document.createElement('div');
  overlay.className = 'overlay';
  overlay.innerHTML = `
    <div class="overlay-sheet">
      <div class="overlay-title">Select Date · June 2025</div>
      <div class="date-scroll">
        ${dates.map(d=>`
