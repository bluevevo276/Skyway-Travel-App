<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#0a0a0f">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>SkyWay — Flights & Trains</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
/* ============================================================
   RESET & BASE
   ============================================================ */
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;-webkit-font-smoothing:antialiased}
:root{
  /* Dark Palette */
  --bg0:#0a0a0f;
  --bg1:#111118;
  --bg2:#1a1a24;
  --bg3:#22222e;
  --bg4:#2a2a38;
  --bg5:#323244;
  /* Accent Colors */
  --accent:#6c63ff;
  --accent-light:rgba(108,99,255,0.15);
  --accent2:#ff6b6b;
  --accent3:#00d4aa;
  --accent4:#ffd93d;
  --accent5:#a78bfa;
  /* Text */
  --text1:#f0f0ff;
  --text2:#a0a0c0;
  --text3:#6060a0;
  --text4:#404060;
  /* Borders / Glow */
  --card-border:rgba(108,99,255,0.18);
  --card-border2:rgba(255,255,255,0.06);
  --glow:rgba(108,99,255,0.35);
  --glow-teal:rgba(0,212,170,0.3);
  /* Semantic */
  --train:#00d4aa;
  --flight:#6c63ff;
  --success:#00d4aa;
  --warning:#ffd93d;
  --danger:#ff6b6b;
  /* Radius */
  --r-sm:8px;
  --r-md:12px;
  --r-lg:16px;
  --r-xl:20px;
  --r-xxl:24px;
}
html,body{height:100%;overflow:hidden;background:var(--bg0)}
body{color:var(--text1);font-family:'DM Sans',sans-serif;font-size:14px;line-height:1.5}
h1,h2,h3,h4,.font-syne{font-family:'Syne',sans-serif}
button{cursor:pointer;border:none;background:none;font-family:inherit;color:inherit}
input,textarea,select{font-family:inherit;outline:none}

/* ============================================================
   APP SHELL
   ============================================================ */
#app{
  width:100%;
  max-width:430px;
  height:100vh;
  height:100dvh;
  margin:0 auto;
  position:relative;
  overflow:hidden;
  background:var(--bg0);
  box-shadow:0 0 80px rgba(108,99,255,0.08);
}

/* ============================================================
   SCREENS & NAVIGATION TRANSITIONS
   ============================================================ */
.screen{
  position:absolute;
  inset:0;
  overflow-y:auto;
  overflow-x:hidden;
  scrollbar-width:none;
  transition:transform 0.42s cubic-bezier(0.4,0,0.2,1),
             opacity 0.42s ease;
  transform:translateX(100%);
  opacity:0;
  pointer-events:none;
  will-change:transform;
}
.screen::-webkit-scrollbar{display:none}
.screen.active{transform:translateX(0);opacity:1;pointer-events:all}
.screen.exit-left{transform:translateX(-30%);opacity:0;pointer-events:none}

/* ============================================================
   STATUS BAR
   ============================================================ */
.statusbar{
  height:46px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:0 22px;
  background:var(--bg0);
  position:sticky;
  top:0;
  z-index:100;
  border-bottom:1px solid rgba(255,255,255,0.03);
}
.statusbar-time{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;letter-spacing:-0.3px}
.statusbar-right{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text2)}
.signal-bar{width:3px;border-radius:1px;background:var(--text2)}

/* ============================================================
   BACK NAV
   ============================================================ */
.back-row{
  display:flex;
  align-items:center;
  gap:10px;
  padding:10px 20px 6px;
  cursor:pointer;
  user-select:none;
  color:var(--text2);
  font-size:13px;
  font-weight:500;
  transition:opacity 0.15s;
}
.back-row:active{opacity:0.5}
.back-circle{
  width:34px;height:34px;
  border-radius:50%;
  background:var(--bg2);
  border:1px solid var(--card-border);
  display:flex;align-items:center;justify-content:center;
  font-size:17px;
  flex-shrink:0;
  transition:background 0.2s;
}
.back-row:hover .back-circle{background:var(--bg3)}

/* ============================================================
   FLOATING CARD (3D PERSPECTIVE)
   ============================================================ */
.card{
  background:var(--bg2);
  border:1px solid var(--card-border);
  border-radius:var(--r-xl);
  position:relative;
  overflow:hidden;
  box-shadow:
    0 8px 32px rgba(0,0,0,0.5),
    0 1px 0 rgba(255,255,255,0.04) inset,
    0 0 0 0.5px rgba(255,255,255,0.02) inset;
  transform:perspective(700px) rotateX(0.8deg);
  transition:transform 0.3s ease,box-shadow 0.3s ease;
}
.card:active{transform:perspective(700px) rotateX(0deg) scale(0.985);box-shadow:0 4px 16px rgba(0,0,0,0.6)}
.card::before{
  content:'';
  position:absolute;
  top:0;left:0;right:0;
  height:1px;
  background:linear-gradient(90deg,transparent,rgba(108,99,255,0.5),transparent);
  pointer-events:none;
}

/* ============================================================
   BOTTOM NAVIGATION
   ============================================================ */
.bottom-nav{
  position:absolute;
  bottom:0;left:0;right:0;
  height:78px;
  background:rgba(10,10,15,0.96);
  border-top:0.5px solid rgba(108,99,255,0.12);
  backdrop-filter:blur(24px) saturate(180%);
  -webkit-backdrop-filter:blur(24px) saturate(180%);
  display:flex;
  z-index:200;
  padding:0 4px 18px;
}
.nav-item{
  flex:1;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:3px;
  cursor:pointer;
  padding:8px 4px;
  position:relative;
  transition:opacity 0.2s;
}
.nav-item:active{opacity:0.6}
.nav-icon-wrap{
  width:46px;height:32px;
  display:flex;align-items:center;justify-content:center;
  border-radius:16px;
  transition:background 0.25s;
  font-size:19px;
}
.nav-item.active .nav-icon-wrap{background:rgba(108,99,255,0.15)}
.nav-label{font-size:10px;font-weight:500;color:var(--text3);transition:color 0.2s}
.nav-item.active .nav-label{color:var(--accent)}
.nav-pill{
  position:absolute;
  top:6px;
  width:18px;height:3px;
  border-radius:2px;
  background:var(--accent);
  opacity:0;
  transition:opacity 0.2s;
}
.nav-item.active .nav-pill{opacity:1}

/* ============================================================
   HOME SCREEN
   ============================================================ */
.home-header{padding:16px 22px 0}
.logo-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px}
.logo{font-family:'Syne',sans-serif;font-size:24px;font-weight:800;letter-spacing:-1px}
.logo em{font-style:normal;color:var(--accent)}
.avatar-btn{
  width:42px;height:42px;
  border-radius:50%;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  display:flex;align-items:center;justify-content:center;
  font-family:'Syne',sans-serif;font-weight:800;font-size:14px;color:white;
  box-shadow:0 0 24px var(--glow);
  border:2px solid rgba(108,99,255,0.3);
  cursor:pointer;
}
.greeting-text{font-size:13px;color:var(--text2);margin-bottom:4px}
.hero-heading{font-family:'Syne',sans-serif;font-size:28px;font-weight:800;line-height:1.15;margin-bottom:20px}
.hero-heading em{font-style:normal;color:var(--accent)}

/* Search card */
.search-card{margin:0 16px 16px;padding:20px;border-radius:var(--r-xxl)}
.mode-switch{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:18px}
.mode-btn{
  padding:11px 8px;
  border-radius:var(--r-lg);
  border:1px solid var(--card-border);
  background:transparent;
  color:var(--text2);
  font-family:'Syne',sans-serif;font-size:13px;font-weight:700;
  display:flex;align-items:center;justify-content:center;gap:6px;
  cursor:pointer;
  transition:all 0.25s ease;
  letter-spacing:0.2px;
}
.mode-btn.active-flight{
  background:var(--accent);
  color:white;
  border-color:var(--accent);
  box-shadow:0 0 24px var(--glow);
}
.mode-btn.active-train{
  background:var(--train);
  color:var(--bg0);
  border-color:var(--train);
  box-shadow:0 0 24px var(--glow-teal);
}

.city-row{display:flex;align-items:flex-end;gap:8px;margin-bottom:10px}
.city-block{flex:1}
.field-label{font-size:9px;text-transform:uppercase;letter-spacing:1.2px;color:var(--text3);margin-bottom:5px;font-weight:600}
.city-pill{
  background:var(--bg3);
  border:1px solid var(--card-border2);
  border-radius:var(--r-md);
  padding:11px 14px;
  cursor:pointer;
  transition:border-color 0.2s,background 0.2s;
}
.city-pill:hover,.city-pill:focus{border-color:var(--accent);background:var(--bg4)}
.city-code{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;line-height:1}
.city-full{font-size:10px;color:var(--text3);margin-top:3px;font-weight:400}
.swap-circle{
  width:38px;height:38px;flex-shrink:0;
  border-radius:50%;
  background:var(--bg3);
  border:1px solid var(--card-border);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;
  font-size:17px;
  transition:all 0.3s cubic-bezier(0.34,1.56,0.64,1);
  margin-bottom:2px;
}
.swap-circle:active{transform:rotate(180deg) scale(0.9)}

.dates-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.date-pill{
  background:var(--bg3);
  border:1px solid var(--card-border2);
  border-radius:var(--r-md);
  padding:11px 14px;
  cursor:pointer;
  transition:border-color 0.2s;
}
.date-pill:hover{border-color:var(--accent)}
.date-val{font-family:'Syne',sans-serif;font-weight:700;font-size:16px}
.date-sub{font-size:10px;color:var(--text3);margin-top:2px}

.cabin-row{display:flex;align-items:center;justify-content:space-between;padding:8px 2px 12px;font-size:12px;color:var(--text2)}
.cabin-chips{display:flex;gap:6px}
.chip{
  padding:5px 12px;
  border-radius:20px;
  background:rgba(108,99,255,0.08);
  border:1px solid rgba(108,99,255,0.2);
  font-size:11px;color:var(--accent);
  cursor:pointer;font-weight:500;
  transition:all 0.2s;white-space:nowrap;
}
.chip.on{background:var(--accent);color:white;border-color:var(--accent)}
.chip:hover{background:rgba(108,99,255,0.2)}

.search-cta{
  width:100%;padding:16px;
  border-radius:var(--r-lg);
  background:linear-gradient(135deg,var(--accent) 0%,#8b5cf6 100%);
  color:white;
  font-family:'Syne',sans-serif;font-weight:700;font-size:16px;
  letter-spacing:0.4px;
  box-shadow:0 6px 28px var(--glow);
  transition:all 0.25s ease;
  position:relative;overflow:hidden;
}
.search-cta::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,0.12),transparent);
  opacity:0;transition:opacity 0.2s;pointer-events:none;
}
.search-cta:hover::after{opacity:1}
.search-cta:active{transform:scale(0.97);box-shadow:0 3px 14px var(--glow)}
.search-cta.teal{background:linear-gradient(135deg,var(--train),#00a88a);box-shadow:0 6px 28px var(--glow-teal)}

/* Promo banner */
.promo-banner{
  margin:0 16px 16px;
  border-radius:var(--r-xxl);
  padding:20px 22px;
  background:var(--bg2);
  border:1px solid rgba(255,107,107,0.2);
  cursor:pointer;
  overflow:hidden;
  position:relative;
  transition:transform 0.2s,border-color 0.2s;
}
.promo-banner::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 80% 50%,rgba(255,107,107,0.07),transparent 60%),
             radial-gradient(ellipse at 20% 50%,rgba(255,217,61,0.04),transparent 60%);
  pointer-events:none;
}
.promo-banner:active{transform:scale(0.98)}
.promo-tag{
  display:inline-flex;align-items:center;gap:5px;
  background:rgba(255,107,107,0.12);
  border:1px solid rgba(255,107,107,0.25);
  border-radius:7px;
  padding:3px 9px;
  font-size:11px;color:var(--accent2);font-weight:700;
  margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px;
}
.promo-heading{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;margin-bottom:4px}
.promo-note{font-size:12px;color:var(--text2)}
.promo-big-num{
  position:absolute;right:22px;top:50%;transform:translateY(-50%);
  font-family:'Syne',sans-serif;font-size:44px;font-weight:800;
  color:var(--accent2);opacity:0.85;line-height:1;text-align:center;
}
.promo-unit{font-size:14px;display:block;margin-top:2px}

/* Popular routes */
.section-head{display:flex;align-items:center;justify-content:space-between;padding:16px 22px 10px}
.section-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:700}
.see-all-btn{font-size:12px;color:var(--accent);cursor:pointer;font-weight:500}

.routes-reel{
  display:flex;gap:12px;
  padding:0 16px 16px;
  overflow-x:auto;scrollbar-width:none;
}
.routes-reel::-webkit-scrollbar{display:none}
.route-tile{
  min-width:154px;
  background:var(--bg2);
  border:1px solid var(--card-border);
  border-radius:var(--r-xl);
  padding:16px;
  cursor:pointer;
  flex-shrink:0;
  position:relative;overflow:hidden;
  transition:transform 0.2s,border-color 0.2s,box-shadow 0.2s;
}
.route-tile::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(108,99,255,0.05),transparent);
  pointer-events:none;
}
.route-tile:hover{border-color:rgba(108,99,255,0.35);box-shadow:0 4px 24px rgba(108,99,255,0.1)}
.route-tile:active{transform:scale(0.95)}
.route-emoji{font-size:26px;margin-bottom:10px;display:block}
.route-label{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;margin-bottom:4px}
.route-cost{font-size:12px;color:var(--accent3);font-weight:500}
.route-badge-small{
  position:absolute;top:10px;right:10px;
  background:rgba(108,99,255,0.15);
  border:1px solid rgba(108,99,255,0.25);
  border-radius:5px;padding:2px 6px;
  font-size:9px;color:var(--accent);font-weight:700;text-transform:uppercase;letter-spacing:0.4px;
}

/* ============================================================
   RESULTS SCREEN
   ============================================================ */
.results-sticky{
  position:sticky;top:0;z-index:50;
  background:var(--bg1);
  border-bottom:0.5px solid rgba(255,255,255,0.05);
  padding:10px 20px 12px;
}
.results-route-title{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;letter-spacing:-0.5px}
.results-meta{font-size:12px;color:var(--text2);margin-top:3px}

.filter-reel{
  display:flex;gap:7px;
  padding:10px 16px 0;
  overflow-x:auto;scrollbar-width:none;
}
.filter-reel::-webkit-scrollbar{display:none}
.fchip{
  padding:7px 15px;
  border-radius:20px;
  border:1px solid var(--card-border);
  background:transparent;
  color:var(--text2);font-size:12px;font-weight:500;
  cursor:pointer;white-space:nowrap;
  transition:all 0.2s;
}
.fchip.on{background:var(--accent);border-color:var(--accent);color:white;box-shadow:0 2px 12px var(--glow)}
.fchip:hover:not(.on){border-color:rgba(108,99,255,0.4)}

/* Flight result card */
.flight-card{
  margin:12px 16px 0;
  background:var(--bg2);
  border:1px solid var(--card-border);
  border-radius:var(--r-xl);
  padding:18px;
  cursor:pointer;
  position:relative;overflow:hidden;
  transition:transform 0.2s,border-color 0.2s,box-shadow 0.2s;
  box-shadow:0 4px 20px rgba(0,0,0,0.3);
}
.flight-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--accent),transparent);
}
.flight-card.best::before{background:linear-gradient(90deg,var(--accent3),transparent)}
.flight-card:hover{border-color:rgba(108,99,255,0.3);box-shadow:0 8px 32px rgba(108,99,255,0.1)}
.flight-card:active{transform:scale(0.985)}

.airline-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.airline-left{display:flex;align-items:center;gap:10px}
.airline-logo-box{
  width:34px;height:34px;border-radius:9px;
  background:var(--bg3);
  display:flex;align-items:center;justify-content:center;
  font-size:16px;border:1px solid var(--card-border2);
}
.airline-name-text{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;color:var(--text1)}
.airline-code-text{font-size:10px;color:var(--text3);margin-top:1px}
.price-block{text-align:right}
.price-main{font-family:'Syne',sans-serif;font-size:23px;font-weight:800;line-height:1}
.price-crossed{font-size:11px;color:var(--text4);text-decoration:line-through}
.price-save{font-size:11px;color:var(--accent3);font-weight:600}

.time-track{display:flex;align-items:center;margin-bottom:10px}
.t-end{min-width:56px}
.t-end.right{text-align:right}
.t-big{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;line-height:1}
.t-code{font-size:10px;color:var(--text3);margin-top:2px}
.middle-track{flex:1;display:flex;flex-direction:column;align-items:center;padding:0 10px}
.dur-text{font-size:11px;color:var(--text3);margin-bottom:5px}
.track-line-wrap{width:100%;display:flex;align-items:center;gap:3px}
.t-dot{width:7px;height:7px;border-radius:50%;background:var(--accent);flex-shrink:0}
.t-line{flex:1;height:1.5px;background:var(--bg5)}
.t-plane{font-size:15px;line-height:1}
.stops-label{font-size:10px;color:var(--text3);margin-top:5px}

.card-bottom{
  display:flex;align-items:center;justify-content:space-between;
  border-top:0.5px solid rgba(255,255,255,0.05);
  padding-top:12px;margin-top:12px;
}
.tag-list{display:flex;flex-wrap:wrap;gap:5px}
.tag{
  padding:3px 8px;border-radius:5px;
  font-size:10px;font-weight:600;
}
.tag-wifi{background:rgba(108,99,255,0.12);color:var(--accent)}
.tag-meal{background:rgba(0,212,170,0.1);color:var(--accent3)}
.tag-usb{background:rgba(255,217,61,0.1);color:var(--accent4)}
.tag-refund{background:rgba(255,107,107,0.1);color:var(--accent2)}
.tag-express{background:rgba(0,212,170,0.1);color:var(--accent3)}

.select-sm-btn{
  padding:8px 18px;border-radius:9px;
  background:var(--accent);color:white;
  font-family:'Syne',sans-serif;font-size:12px;font-weight:700;
  box-shadow:0 2px 14px var(--glow);
  transition:all 0.2s;white-space:nowrap;flex-shrink:0;
}
.select-sm-btn:active{transform:scale(0.94)}
.best-value-badge{
  display:inline-flex;align-items:center;gap:4px;
  background:rgba(0,212,170,0.1);
  border:1px solid rgba(0,212,170,0.25);
  border-radius:6px;padding:3px 9px;
  font-size:10px;color:var(--accent3);font-weight:700;
  margin-bottom:10px;text-transform:uppercase;letter-spacing:0.4px;
}

/* Train result card */
.train-card{
  margin:12px 16px 0;
  background:var(--bg2);
  border:1px solid rgba(0,212,170,0.15);
  border-radius:var(--r-xl);
  padding:18px;
  cursor:pointer;
  position:relative;overflow:hidden;
  transition:transform 0.2s,border-color 0.2s,box-shadow 0.2s;
}
.train-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--train),transparent);
}
.train-card:hover{border-color:rgba(0,212,170,0.3);box-shadow:0 8px 32px rgba(0,212,170,0.08)}
.train-card:active{transform:scale(0.985)}
.train-num-text{font-family:'Syne',sans-serif;font-size:12px;font-weight:700;color:var(--train);letter-spacing:0.5px}
.train-name-text{font-family:'Syne',sans-serif;font-size:15px;font-weight:700}
.train-type-text{font-size:11px;color:var(--text3)}
.avail-pill{
  display:inline-flex;align-items:center;gap:4px;
  padding:3px 9px;border-radius:5px;
  font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.3px;
}
