/* ── Navigation ── */
function goTo(id){
  document.querySelectorAll('.screen').forEach(s=>{
    if(s.id !== id){
      if(s.classList.contains('active')){
        s.classList.replace('active','exit-left');
        setTimeout(()=>s.classList.remove('exit-left'),480);
      }
    }
  });
  const target = document.getElementById(id);
  if(!target) return;
  target.classList.remove('exit-left');
  target.classList.add('active');
  target.scrollTop = 0;
}
function goHome(){ goTo('screen-home'); }

/* ── Mode Toggle ── */
function setMode(m){
  S.mode = m;
  const tbF = document.getElementById('tab-flight');
  const tbT = document.getElementById('tab-train');
  const bgI = document.getElementById('card-bg-icon');
  tbF.className = 'mode-btn' + (m==='flight' ? ' active-flight' : '');
  tbT.className = 'mode-btn' + (m==='train'  ? ' active-train'  : '');
  document.getElementById('flight-search').style.display = m==='flight' ? '' : 'none';
  document.getElementById('train-search').style.display  = m==='train'  ? '' : 'none';
  if(bgI) bgI.textContent = m==='train' ? '🚄' : '✈';
}

/* ── City Swap ── */
function swapCities(){
  [S.from, S.to] = [S.to, S.from];
  [S.fromName, S.toName] = [S.toName, S.fromName];
  document.getElementById('from-code').textContent = S.from;
  document.getElementById('to-code').textContent   = S.to;
  document.getElementById('from-full').textContent = S.fromName + ', India';
  document.getElementById('to-full').textContent   = S.toName   + ', India';
}

/* ── Cabin Class ── */
function setCabin(el, cls){
  document.querySelectorAll('.cabin-chips .chip').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  S.cabinClass = cls;
}

/* ── Quick Search (route tiles) ── */
function quickSearch(from, to, fromName, toName){
  S.from = from; S.to = to;
  S.fromName = fromName; S.toName = toName;
  document.getElementById('from-code').textContent = from;
  document.getElementById('to-code').textContent   = to;
  document.getElementById('from-full').textContent = fromName + ', India';
  document.getElementById('to-full').textContent   = toName   + ', India';
  goToResults('flight');
}

/* ── City Picker ── */
function openCityPicker(target){
  const list = (target.includes('train')) ? TRAIN_STATIONS : CITIES;
  const overlay = document.createElement('div');
  overlay.className = 'overlay';
  overlay.innerHTML = `
    <div class="overlay-sheet">
      <div class="overlay-title">Select City</div>
      ${list.map(c=>`
      <div class="city-option" onclick="pickCity('${target}','${c.code}','${c.name}')">
        <div class="city-code-box">${c.code}</div>
        <div>
          <div class="city-info-name">${c.name}</div>
          <div class="city-info-sub">${c.country}</div>
        </div>
      </div>`).join('')}
    </div>`;
  overlay.onclick = e => { if(e.target === overlay) document.body.removeChild(overlay); };
  document.getElementById('app').appendChild(overlay);
  window._overlay = overlay;
}
function pickCity(target, code, name){
  if(target==='from'){ S.from=code; S.fromName=name; document.getElementById('from-code').textContent=code; document.getElementById('from-full').textContent=name+', India'; }
  else if(target==='to'){ S.to=code; S.toName=name; document.getElementById('to-code').textContent=code; document.getElementById('to-full').textContent=name+', India'; }
  else if(target==='from-train'){ document.getElementById('from-train-code').textContent=code; document.getElementById('from-train-full').textContent=name; }
  else if(target==='to-train'){ document.getElementById('to-train-code').textContent=code; document.getElementById('to-train-full').textContent=name; }
  if(window._overlay) try{ document.getElementById('app').removeChild(window._overlay); }catch(e){}
}

