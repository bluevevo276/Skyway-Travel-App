function toggleSeat(id){
  const el = document.getElementById('s-'+id);
  if(!el) return;
  if(S.selectedSeats.includes(id)){
    S.selectedSeats = S.selectedSeats.filter(s=>s!==id);
    el.classList.remove('selected');
  } else {
    if(S.selectedSeats.length >= S.adults){ return; }
    S.selectedSeats.push(id);
    el.classList.add('selected');
  }
}
function selectFlightClass(el){
  document.querySelectorAll('.cls-opt').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
}

