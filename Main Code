      </div>
      <div class="pay-option" id="pay-nb" onclick="selectPay('nb')">
        <div class="pay-icon-box" style="background:rgba(0,212,170,0.1)">🏦</div>
        <div><div class="pay-name">Net Banking</div><div class="pay-sub">SBI, HDFC, ICICI, Axis +200 more</div></div>
        <div class="pay-radio"><div class="pay-radio-dot"></div></div>
      </div>
      <div class="pay-option" id="pay-wallet" onclick="selectPay('wallet')">
        <div class="pay-icon-box" style="background:rgba(255,217,61,0.1)">👝</div>
        <div><div class="pay-name">Wallets</div><div class="pay-sub">Paytm, Amazon Pay, Freecharge</div></div>
        <div class="pay-radio"><div class="pay-radio-dot"></div></div>
      </div>
      <div class="pay-option" id="pay-emi" onclick="selectPay('emi')">
        <div class="pay-icon-box" style="background:rgba(108,99,255,0.08)">📅</div>
        <div><div class="pay-name">No Cost EMI</div><div class="pay-sub">3, 6, 12 months · No interest</div></div>
        <div class="pay-radio"><div class="pay-radio-dot"></div></div>
      </div>
    </div>

    <div id="upi-detail" style="margin:10px 16px">
      <div style="background:var(--bg2);border:1px solid var(--card-border);border-radius:var(--r-lg);padding:14px">
        <div class="f-label" style="margin-bottom:8px">UPI ID or VPA</div>
        <input class="f-input" value="arjun@oksbi" placeholder="name@upi" style="margin-bottom:8px">
        <div style="font-size:11px;color:var(--text3)">Or scan QR code at the payment page</div>
      </div>
    </div>

    <div class="promo-box">
      <div class="promo-input-row">
        <div style="font-size:17px">🏷</div>
        <input class="f-input" placeholder="Enter promo code" style="flex:1" id="promo-input">
        <button class="promo-apply-btn" onclick="applyPromo()">Apply</button>
      </div>
      <div class="cabin-chips" style="flex-wrap:wrap;gap:6px">
        <div class="chip" onclick="fillPromo('SKYWAY10')">SKYWAY10</div>
        <div class="chip" onclick="fillPromo('FIRST500')">FIRST500</div>
        <div class="chip" onclick="fillPromo('HDFC200')">HDFC200</div>
        <div class="chip" onclick="fillPromo('MONSOON')">MONSOON</div>
      </div>
      <div id="promo-msg" style="font-size:12px;color:var(--accent3);margin-top:8px;display:none">✓ Promo applied! ₹500 saved</div>
    </div>

    <div class="total-box">
      <div class="total-row">
        <div style="font-size:13px;color:var(--text2)">Total Payable</div>
        <div style="font-family:Syne,sans-serif;font-size:24px;font-weight:800">₹${total.toLocaleString('en-IN')}</div>
      </div>
      <div class="secure-note">🔒 256-bit SSL · PCI-DSS Compliant payment</div>
