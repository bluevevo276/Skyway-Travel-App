    <div style="height:90px"></div>
    <div class="sticky-footer">
      <div>
        <div class="footer-price-label">Paying</div>
        <div class="footer-price-big">₹${total.toLocaleString('en-IN')}</div>
      </div>
      <button class="cta-btn${isTrain?' teal':''}" id="pay-now-btn" onclick="processPayment(${total})">
        Pay ₹${total.toLocaleString('en-IN')} →
      </button>
